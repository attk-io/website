---
type Props = {
  title: string;
  description?: string;
};

const { title, description = 'Custom cloud software and automation consulting' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="author" content="Christian Naths" />
    <meta name="description" content={description} />
    <link
      rel="shortcut icon"
      type="image/png"
      href="data:image/png;base64,"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  body {
    font-family: 'DM Sans', sans-serif;
    color: #2c2622;
    background: #faf7f2;
    font-size: 1.125rem;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: 'EB Garamond', serif;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }
</style>
