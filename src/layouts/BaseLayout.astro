---
import '../styles/global.css';

type Props = {
  title: string;
  description?: string;
};

const { title, description = 'Custom cloud software and automation consulting' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="author" content="Christian Naths" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="shortcut icon"
      type="image/png"
      href="data:image/png;base64,"
    />
  </head>
  <body class="bg-sand-1 text-sand-12 antialiased">
    <slot />
  </body>
</html>
