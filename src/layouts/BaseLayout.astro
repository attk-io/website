---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Custom cloud software and automation consulting' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="default">
  <head>
    <script is:inline>
      const t = localStorage.getItem('attk-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
    </script>
    <script is:inline>
      (function() {
        var v = localStorage.getItem('attk-copy-variant') || 'v1';
        var s = document.createElement('style');
        s.id = 'copy-variant-style';
        s.textContent = '[data-copy-variant]:not([data-copy-variant="' + v + '"]){display:none!important}';
        document.head.appendChild(s);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="author" content="Christian Naths" />
    <meta name="description" content={description} />
    <link
      rel="shortcut icon"
      type="image/png"
      href="data:image/png;base64,"
    />
    <link
      href="https://fonts.googleapis.com/css?family=Fira+Sans:400,600|Source+Serif+Pro:700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
