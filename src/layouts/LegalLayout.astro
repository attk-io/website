---
interface Props {
  title: string;
}

import BaseLayout from './BaseLayout.astro';

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <main class="mx-auto max-w-3xl px-6 py-12">
    <a
      href="/"
      class="mb-8 inline-block text-sm font-semibold text-sand-12 hover:underline"
    >
      &larr; Back to home
    </a>
    <article>
      <slot />
    </article>
  </main>
</BaseLayout>
