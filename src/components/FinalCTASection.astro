---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="cta">
  <div class="cta-inner" set:html={html} />
</section>

<style>
  .cta {
    padding: clamp(5rem, 14vh, 9rem) 1.5rem;
    text-align: center;
    background: #b84c2a;
  }

  .cta-inner {
    max-width: 30rem;
    margin: 0 auto;
  }

  .cta :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    color: #faf7f2;
    margin: 0 0 1rem;
  }

  .cta :global(p) {
    font-family: 'DM Mono', monospace;
    color: #f4ede4;
    margin: 0 0 2rem;
    font-size: 0.95rem;
  }

  .cta :global(p:last-child) {
    margin-bottom: 0;
  }

  .cta :global(a) {
    display: inline-block;
    background: #faf7f2;
    color: #b84c2a;
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.85rem 2.25rem;
    border-radius: 3px;
    transition: background 0.2s ease;
  }

  .cta :global(a:hover) {
    background: #fff;
  }
</style>
