---
const phases = [
  {
    number: 1,
    name: 'Discovery',
    description:
      'Understand your vision, business context, and what success looks like.',
  },
  {
    number: 2,
    name: 'Audience',
    description:
      'Define who the product is for and what problem it solves for them.',
  },
  {
    number: 3,
    name: 'Scope',
    description:
      'Translate insights into a focused, buildable plan with clear boundaries.',
  },
  {
    number: 4,
    name: 'Build',
    description:
      'Design and develop in short cycles, prioritizing speed to market.',
  },
  {
    number: 5,
    name: 'Launch',
    description:
      'Get the product into real users\u2019 hands with smooth deployment.',
  },
  {
    number: 6,
    name: 'Iterate',
    description:
      'Collect feedback, measure results, decide what to improve or cut.',
  },
];
---

<section class="py-16 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-serif text-3xl font-bold mb-12">How we work together</h2>
    <div class="relative">
      {
        phases.map((phase, i) => (
          <div
            class:list={[
              'relative pl-10 pb-10',
              i < phases.length - 1 && 'border-l-2 border-separator',
              i === phases.length - 1 && 'border-l-2 border-transparent',
            ]}
          >
            <div class="absolute -left-3 top-0 w-6 h-6 bg-accent border-2 border-outline rounded-full flex items-center justify-center text-xs font-bold">
              {phase.number}
            </div>
            <h3 class="font-serif text-xl font-bold mb-1">{phase.name}</h3>
            <p class="text-muted">{phase.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
