---
import { variants as copyVariants } from './copy-variants/manifest';
import { designVariants } from './variants/manifest';

type Props = {
  currentVariant?: string;
};

const { currentVariant } = Astro.props;

const toolbarData = {
  designVariants: designVariants.map((v) => ({
    id: v.id,
    label: v.label,
    slug: v.slug,
  })),
  copyVariants: copyVariants.map((v) => ({ id: v.id, label: v.label, tone: v.tone })),
  currentVariant: currentVariant ?? designVariants[0].slug,
};
---

<div
  id="review-toolbar-host"
  data-toolbar={JSON.stringify(toolbarData)}
  style="display:contents"
>
</div>

<script is:inline>
      (function () {
        const host = document.getElementById('review-toolbar-host');
        if (!host) return;

        const data = JSON.parse(host.dataset.toolbar);
        const VARIANT_KEY = 'attk-copy-variant';
        const VARIANT_PARAM = 'variant';
        const TOOLBAR_HEIGHT = 56;
        const validCopyVariants = data.copyVariants.map(function (v) { return v.id; });

        const shadow = host.attachShadow({ mode: 'open' });

        const style = document.createElement('style');
        style.textContent = `
          :host {
            all: initial;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
          }
          .bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 2147483647;
            height: ${TOOLBAR_HEIGHT}px;
            background: #0f0f1a;
            border-bottom: 1px solid #2a2a40;
            color: #f5f5fa;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 0 1rem;
            font-size: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
            box-sizing: border-box;
            overflow-x: auto;
            white-space: nowrap;
          }
          .brand {
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #a78bfa;
            padding-right: 1rem;
            border-right: 1px solid #2a2a40;
          }
          .group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
          }
          .label {
            color: #8a8aa3;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-size: 10px;
          }
          .items {
            display: flex;
            gap: 0.25rem;
          }
          button, a.nav-link {
            background: transparent;
            color: #c5c5d6;
            border: 1px solid #2a2a40;
            padding: 0.375rem 0.625rem;
            border-radius: 4px;
            font-size: 11px;
            font-family: inherit;
            cursor: pointer;
            transition: background 0.1s, border-color 0.1s, color 0.1s;
            text-decoration: none;
            display: inline-block;
            line-height: 1.2;
          }
          button:hover, a.nav-link:hover {
            background: #1a1a2e;
            border-color: #3a3a55;
            color: #fff;
          }
          button[data-active='true'], a.nav-link[data-active='true'] {
            background: #a78bfa;
            border-color: #a78bfa;
            color: #0f0f1a;
            font-weight: 600;
          }
        `;
        shadow.appendChild(style);

        const bar = document.createElement('div');
        bar.className = 'bar';

        const brand = document.createElement('div');
        brand.className = 'brand';
        brand.textContent = 'Review';
        bar.appendChild(brand);

        // Design variant navigation
        const designGroup = createGroup('Design');
        data.designVariants.forEach(function (variant) {
          const link = document.createElement('a');
          link.className = 'nav-link';
          link.textContent = variant.label;
          link.href = '/variants/' + variant.slug + '/';
          link.dataset.value = variant.slug;
          link.dataset.active = variant.slug === data.currentVariant ? 'true' : 'false';
          designGroup.itemsEl.appendChild(link);
        });
        bar.appendChild(designGroup.el);

        // Copy variant buttons
        const copyGroup = createGroup('Copy');
        const copyButtons = data.copyVariants.map(function (variant) {
          return createButton(variant.id, variant.id + ' \u00b7 ' + variant.tone, function () {
            setCopyVariant(variant.id);
          });
        });
        copyButtons.forEach(function (btn) { copyGroup.itemsEl.appendChild(btn); });
        bar.appendChild(copyGroup.el);

        shadow.appendChild(bar);

        const bodyPadStyle = document.createElement('style');
        bodyPadStyle.textContent = 'body { padding-top: ' + TOOLBAR_HEIGHT + 'px !important; }';
        document.head.appendChild(bodyPadStyle);

        // Initialize copy variant
        const url = new URL(window.location.href);
        const urlVariant = url.searchParams.get(VARIANT_PARAM);
        const initialVariant =
          (urlVariant && validCopyVariants.indexOf(urlVariant) !== -1 && urlVariant) ||
          localStorage.getItem(VARIANT_KEY) ||
          'v1';
        applyCopyVariant(initialVariant);
        localStorage.setItem(VARIANT_KEY, initialVariant);
        syncUrl(initialVariant);
        updateActiveButton(copyButtons, initialVariant);

        function createGroup(labelText) {
          const el = document.createElement('div');
          el.className = 'group';
          const label = document.createElement('span');
          label.className = 'label';
          label.textContent = labelText;
          const itemsEl = document.createElement('div');
          itemsEl.className = 'items';
          el.appendChild(label);
          el.appendChild(itemsEl);
          return { el, itemsEl };
        }

        function createButton(value, text, onClick) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.dataset.value = value;
          btn.textContent = text;
          btn.addEventListener('click', onClick);
          return btn;
        }

        function updateActiveButton(buttons, activeValue) {
          buttons.forEach(function (btn) {
            btn.dataset.active = btn.dataset.value === activeValue ? 'true' : 'false';
          });
        }

        function setCopyVariant(variant) {
          applyCopyVariant(variant);
          localStorage.setItem(VARIANT_KEY, variant);
          updateActiveButton(copyButtons, variant);
          syncUrl(variant);
        }

        function syncUrl(variant) {
          const next = new URL(window.location.href);
          next.searchParams.set(VARIANT_PARAM, variant);
          window.history.replaceState(null, '', next.toString());
        }

        function applyCopyVariant(variant) {
          const existing = document.getElementById('copy-variant-style');
          const css = '[data-copy-variant]:not([data-copy-variant="' + variant + '"]){display:none!important}';
          if (existing) {
            existing.textContent = css;
            return;
          }
          const styleEl = document.createElement('style');
          styleEl.id = 'copy-variant-style';
          styleEl.textContent = css;
          document.head.appendChild(styleEl);
        }
      })();
    </script>
