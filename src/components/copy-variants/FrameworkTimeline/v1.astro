---
export const label = 'Strategic partnership; punchy, direct';

const phases = [
  {
    number: 1,
    name: 'Align',
    tagline: 'We figure out if I\u2019m the right person for what you need.',
    description:
      'You tell me about your vision, your market, and what\u2019s at stake. I tell you honestly whether I can help and what it\u2019ll take. No pitch deck, no sales process. Just a conversation between two people deciding if they want to work together.',
  },
  {
    number: 2,
    name: 'Plan',
    tagline: 'I turn your vision into a plan you can actually read.',
    description:
      'I translate what you need into a technical strategy\u200a\u2014\u200ain plain language, not jargon. We agree on what gets built first, what waits, and what gets cut entirely. You\u2019ll know exactly where your money goes and why.',
  },
  {
    number: 3,
    name: 'Build',
    tagline: 'You see progress every week, not every quarter.',
    description:
      'I design and develop in short cycles. You get regular updates you can understand\u200a\u2014\u200awhat\u2019s done, what\u2019s next, what changed and why. You stay focused on the business. I handle the technical decisions.',
  },
  {
    number: 4,
    name: 'Launch',
    tagline: 'A real product in real users\u2019 hands.',
    description:
      'Not a demo. Not a prototype. A product\u200a\u2014\u200adeployed, monitored, and ready for the market. I handle the infrastructure, the deployment, and the things you didn\u2019t know you needed to worry about.',
  },
  {
    number: 5,
    name: 'Adapt',
    tagline: 'We decide what\u2019s next\u200a\u2014\u200atogether.',
    description:
      'Real users generate real data. We look at what\u2019s working, what isn\u2019t, and where the biggest opportunities are. I tell you what\u2019s possible technically. You decide what matters for the business. We plan the next cycle.',
  },
];
---

<section class="py-16 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-serif text-3xl font-bold mb-12">From concept to launched product</h2>
    <div class="relative">
      {
        phases.map((phase, i) => (
          <div
            class:list={[
              'relative pl-10 pb-10',
              i < phases.length - 1 && 'border-l-2 border-separator',
              i === phases.length - 1 && 'border-l-2 border-transparent',
            ]}
          >
            <div class="absolute -left-3 top-0 w-6 h-6 bg-accent border-2 border-outline rounded-full flex items-center justify-center text-xs font-bold">
              {phase.number}
            </div>
            <h3 class="font-serif text-xl font-bold mb-1">{phase.name}</h3>
            <p class="text-muted italic mb-2">{phase.tagline}</p>
            <p class="text-muted">{phase.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
