---
type Accent = 'ocean' | 'plum' | 'sun';

type Props = {
  number?: string;
  label: string;
  accent?: Accent;
  onDark?: boolean;
};

const { number, label, accent = 'ocean', onDark = false } = Astro.props;

const NUMERAL_CLASS: Record<Accent, string> = {
  ocean: 'text-ocean-11',
  plum: 'text-plum-11',
  sun: 'text-sun-9',
};

const labelClass = onDark ? 'text-sand-3' : 'text-sand-11';
const ruleClass = onDark ? 'bg-sand-1/30' : 'bg-sand-7';
const numeralClass = NUMERAL_CLASS[accent];
---

<div class="mb-12 flex items-baseline gap-6">
  <span class="text-[0.75rem] font-medium tracking-[0.14em] uppercase">
    {number && <span class={numeralClass}>{number}</span>}
    {number && <span class={labelClass}> · </span>}
    <span class={labelClass}>{label}</span>
  </span>
  <span aria-hidden="true" class={`h-px flex-1 ${ruleClass}`}></span>
</div>
