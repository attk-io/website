---
import { renderMarkdown } from '../lib/markdown';

type Props = {
  content: string;
};

const { content } = Astro.props;

const html = renderMarkdown(content, {
  h2: 'font-display text-[clamp(1.15rem,2.5vw,1.35rem)] font-medium text-sand-12 mb-10 leading-snug',
  h3: 'font-mono text-[1.05rem] font-medium text-copper-9 mt-9 mb-2 pt-9 border-t border-sand-6 leading-snug [&:first-of-type]:mt-0 [&:first-of-type]:pt-0 [&:first-of-type]:border-t-0',
  p: 'text-sand-11 mb-2 last:mb-0',
});
---

<section class="px-6 py-[clamp(3.5rem,8vh,6rem)]">
  <div class="mx-auto max-w-[36rem]" set:html={html} />
</section>
