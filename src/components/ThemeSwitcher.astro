<div
  id="theme-switcher"
  style="position:fixed;bottom:1rem;right:1rem;z-index:9999;"
>
  <select
    id="theme-select"
    style="padding:0.5rem 0.75rem;border-radius:0.25rem;border:1px solid #ccc;font-size:0.875rem;background:white;cursor:pointer;"
  >
    <option value="default">Default</option>
    <option value="ocean">Ocean</option>
  </select>
</div>

<script>
  const select = document.getElementById(
    'theme-select'
  ) as HTMLSelectElement | null;
  if (select) {
    const saved = localStorage.getItem('attk-theme');
    if (saved) {
      document.documentElement.setAttribute('data-theme', saved);
      select.value = saved;
    }
    select.addEventListener('change', (e) => {
      const theme = (e.target as HTMLSelectElement).value;
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('attk-theme', theme);
    });
  }
</script>
