---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="py-24 md:py-32 px-6 text-center bg-surface-emphasis">
  <div
    class:list={[
      'max-w-2xl mx-auto',
      '[&>h2]:font-serif [&>h2]:text-2xl [&>h2]:md:text-3xl [&>h2]:font-bold [&>h2]:mb-5 [&>h2]:leading-snug',
      '[&>p]:text-lg [&>p]:text-muted [&>p]:mb-10 [&>p:last-child]:mb-0 [&>p]:leading-relaxed',
      '[&>p>a]:inline-block [&>p>a]:bg-accent [&>p>a]:text-on-accent [&>p>a]:font-semibold [&>p>a]:px-10 [&>p>a]:py-3.5 [&>p>a]:text-base [&>p>a]:tracking-wide [&>p>a]:transition-all [&>p>a]:duration-200 [&>p>a]:hover:brightness-110 [&>p>a]:active:brightness-95',
    ]}
    set:html={html}
  />
</section>
