---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="py-20 md:py-24 px-6">
  <div
    class:list={[
      'max-w-3xl mx-auto',
      '[&>h2]:font-serif [&>h2]:text-2xl [&>h2]:md:text-3xl [&>h2]:font-bold [&>h2]:mb-12 [&>h2]:leading-snug',
      '[&>p]:border-b [&>p]:border-separator [&>p]:pb-8 [&>p]:mb-8 [&>p:last-child]:border-0 [&>p:last-child]:pb-0 [&>p:last-child]:mb-0',
      '[&>p]:text-muted [&>p]:leading-relaxed',
      '[&>p>strong]:text-accent-muted [&>p>strong]:text-base [&>p>strong]:md:text-lg [&>p>strong]:block [&>p>strong]:mb-3 [&>p>strong]:font-semibold [&>p>strong]:font-serif',
    ]}
    set:html={html}
  />
</section>
