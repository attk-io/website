---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="py-20 md:py-24 px-6 bg-surface">
  <div
    class:list={[
      'max-w-3xl mx-auto',
      '[&>h2]:font-serif [&>h2]:text-2xl [&>h2]:md:text-3xl [&>h2]:font-bold [&>h2]:mb-8 [&>h2]:leading-snug',
      '[&>p]:text-lg [&>p]:leading-relaxed [&>p]:text-muted [&>p]:mb-5 [&>p:last-child]:mb-0',
    ]}
    set:html={html}
  />
</section>
