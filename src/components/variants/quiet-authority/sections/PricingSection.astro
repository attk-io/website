---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="pricing">
  <div class="pricing-inner" set:html={html} />
</section>

<style>
  .pricing {
    padding: clamp(3.5rem, 8vh, 6rem) 1.5rem;
  }

  .pricing-inner {
    max-width: 36rem;
    margin: 0 auto;
  }

  .pricing :global(h2) {
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    font-weight: 500;
    color: #2c2622;
    margin: 0 0 2.5rem;
    line-height: 1.45;
  }

  .pricing :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #b84c2a;
    margin: 2.25rem 0 0.5rem;
    padding-top: 2.25rem;
    border-top: 1px solid #ddd5cb;
    letter-spacing: 0;
    line-height: 1.3;
  }

  .pricing :global(h3:first-of-type) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .pricing :global(p) {
    color: #3d3530;
    margin: 0 0 0.5rem;
  }

  .pricing :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
