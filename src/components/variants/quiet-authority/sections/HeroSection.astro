---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="hero">
  <div class="hero-inner" set:html={html} />
</section>

<style>
  .hero {
    padding: clamp(6rem, 18vh, 12rem) 1.5rem clamp(4rem, 12vh, 7rem);
    text-align: center;
    border-bottom: 2px solid #c9bfb2;
  }

  .hero-inner {
    max-width: 38rem;
    margin: 0 auto;
  }

  .hero :global(h1) {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #2c2622;
    margin: 0 0 1.75rem;
  }

  .hero :global(h3) {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    font-weight: 400;
    line-height: 1.65;
    color: #5a5148;
    margin: 0 auto 2.5rem;
    max-width: 30rem;
    letter-spacing: 0;
  }

  .hero :global(p) {
    margin: 0;
  }

  .hero :global(a) {
    display: inline-block;
    background: #b84c2a;
    color: #faf7f2;
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    padding: 0.85rem 2.25rem;
    border-radius: 3px;
    transition: background 0.2s ease;
  }

  .hero :global(a:hover) {
    background: #a34122;
  }
</style>
