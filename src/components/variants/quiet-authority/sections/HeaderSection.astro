---
// Quiet Authority — site header with logo and wordmark
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">
      <img src="/favicon.png" alt="" width="20" height="20" />
      <span>ATTK</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    padding: 1.25rem 1.5rem;
  }

  .site-header-inner {
    max-width: 38rem;
    margin: 0 auto;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #2c2622;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .site-logo img {
    display: block;
    opacity: 0.8;
  }
</style>
