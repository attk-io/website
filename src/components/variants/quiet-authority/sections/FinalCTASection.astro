---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="cta">
  <div class="cta-inner" set:html={html} />
</section>

<style>
  .cta {
    padding: clamp(4rem, 10vh, 7rem) 1.5rem;
    text-align: center;
    border-top: 1px solid #ddd5cb;
  }

  .cta-inner {
    max-width: 30rem;
    margin: 0 auto;
  }

  .cta :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    color: #2c2622;
    margin: 0 0 1rem;
  }

  .cta :global(p) {
    color: #736a60;
    margin: 0 0 2rem;
    font-size: 1.05rem;
  }

  .cta :global(p:last-child) {
    margin-bottom: 0;
  }

  .cta :global(a) {
    color: #b84c2a;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    text-decoration-color: #b84c2a66;
    font-weight: 500;
    font-size: 1.1rem;
    transition: text-decoration-color 0.2s ease;
  }

  .cta :global(a:hover) {
    text-decoration-color: #b84c2a;
  }
</style>
