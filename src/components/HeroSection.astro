---
import { renderMarkdown } from '../lib/markdown';
import { TYPOGRAPHY_BASELINE } from '../lib/typography';

type Props = {
  content: string;
  eyebrow?: string;
};

const { content, eyebrow } = Astro.props;

const heroClasses = {
  ...TYPOGRAPHY_BASELINE,
  h1: 'max-w-[14ch] text-[clamp(2.875rem,6vw+0.5rem,5.25rem)] font-semibold leading-[0.96] tracking-[-0.035em] text-sand-12',
  h3: 'mt-8 max-w-[52ch] font-dm-mono text-[clamp(0.9375rem,0.5vw+0.75rem,1.0625rem)] font-normal leading-[1.7] tracking-[0] text-sand-11',
  p: 'mt-12 text-[1.0625rem] leading-[1.6] text-sand-12',
  a: 'text-[1.0625rem] font-medium text-sun-11 underline decoration-sun-7 decoration-[2px] underline-offset-[6px] hover:decoration-sun-11 transition-colors duration-150',
};

const html = renderMarkdown(content, heroClasses);
---

<section class="px-6 pt-32 pb-24 sm:px-10 sm:pt-44 sm:pb-32">
  <div class="mx-auto grid max-w-[120rem] grid-cols-[1fr_minmax(0,44rem)_3fr]">
    <div class="col-start-2">
      {
        eyebrow && (
          <div class="mb-12 flex items-baseline gap-6">
            <span class="text-[0.75rem] font-medium tracking-[0.14em] text-sand-11 uppercase">
              {eyebrow}
            </span>
            <span aria-hidden="true" class="h-px flex-1 bg-sand-7" />
          </div>
        )
      }
      <div set:html={html} />
    </div>
  </div>
</section>
