---
import { renderMarkdown } from '../lib/markdown';
import { TYPOGRAPHY_BASELINE } from '../lib/typography';
import SectionEyebrow from './SectionEyebrow.astro';

type Props = {
  content: string;
  number?: string;
  label?: string;
};

const { content, number, label } = Astro.props;

const heroClasses = {
  ...TYPOGRAPHY_BASELINE,
  h1: 'max-w-[14ch] text-[clamp(2.875rem,6vw+0.5rem,5.25rem)] font-semibold leading-[0.96] tracking-[-0.035em] text-sand-12',
  h3: 'mt-8 max-w-[52ch] font-dm-mono text-[clamp(0.9375rem,0.5vw+0.75rem,1.0625rem)] font-normal leading-[1.7] tracking-[0] text-sand-11',
  p: 'mt-12 text-[1.0625rem] leading-[1.6] text-sand-12',
  a: 'text-[1.0625rem] font-medium text-ocean-11 underline decoration-ocean-7 decoration-[2px] underline-offset-[6px] hover:decoration-ocean-11 transition-colors duration-150',
};

const html = renderMarkdown(content, heroClasses);
---

<section class="px-6 pt-32 pb-24 sm:px-10 sm:pt-44 sm:pb-32">
  <div class="mx-auto grid max-w-480 grid-cols-[1fr_minmax(0,44rem)_3fr]">
    <div class="col-start-2">
      {label && <SectionEyebrow number={number} label={label} />}
      <div set:html={html} />
    </div>
  </div>
</section>
