---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const rawHtml = await marked(content);
const html = rawHtml.replace(/<h3>(?:Phase )?\d+[.:]\s*/g, '<h3>');
---

<section class="how">
  <div class="how-inner" set:html={html} />
</section>

<style>
  .how {
    padding: clamp(3.5rem, 8vh, 6rem) 1.5rem;
    border-top: 2px solid #c9bfb2;
  }

  .how-inner {
    max-width: 36rem;
    margin: 0 auto;
    counter-reset: phase;
  }

  .how :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    color: #2c2622;
    margin: 0 0 2.5rem;
    padding-left: 1.25rem;
    border-left: 4px solid #b84c2a;
    line-height: 1.25;
  }

  .how :global(h3) {
    font-family: 'DM Mono', monospace;
    font-size: 1rem;
    font-weight: 500;
    color: #b84c2a;
    margin: 3rem 0 0.75rem;
    letter-spacing: 0;
    line-height: 1.3;
    counter-increment: phase;
  }

  .how :global(h3::before) {
    content: counter(phase, decimal-leading-zero) ".";
    display: block;
    font-family: 'EB Garamond', serif;
    font-size: 2.5rem;
    font-weight: 300;
    color: #c9bfb2;
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .how :global(h3:first-of-type) {
    margin-top: 0;
  }

  .how :global(p) {
    color: #3d3530;
    margin: 0 0 0.5rem;
  }

  .how :global(p:last-child) {
    margin-bottom: 0;
  }

  .how :global(a) {
    color: #b84c2a;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: #b84c2a66;
  }

  .how :global(a:hover) {
    text-decoration-color: #b84c2a;
  }
</style>
