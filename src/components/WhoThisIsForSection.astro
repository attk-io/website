---
import { renderMarkdown } from '../lib/markdown';
import { TYPOGRAPHY_BASELINE } from '../lib/typography';

type Props = {
  content: string;
  eyebrow?: string;
};

const { content, eyebrow } = Astro.props;

const classes = {
  ...TYPOGRAPHY_BASELINE,
  // Long declarative H2 acts as a sub-hero — give it a max-width so it
  // wraps with intent and slightly tighter tracking for the larger size.
  h2: 'max-w-[24ch] text-[clamp(2rem,3vw+0.75rem,2.875rem)] font-semibold leading-[1.05] tracking-[-0.028em] text-sand-12',
  p: 'mt-8 max-w-[68ch] text-[1.0625rem] leading-[1.65] text-sand-12',
};

const html = renderMarkdown(content, classes);
---

<section class="px-6 py-24 sm:px-10 sm:py-32">
  <div class="mx-auto grid max-w-[120rem] grid-cols-[1fr_minmax(0,44rem)_3fr]">
    <div class="col-start-2">
      {
        eyebrow && (
          <div class="mb-12 flex items-baseline gap-6">
            <span class="text-[0.75rem] font-medium tracking-[0.14em] text-sand-11 uppercase">
              {eyebrow}
            </span>
            <span aria-hidden="true" class="h-px flex-1 bg-sand-7" />
          </div>
        )
      }
      <div set:html={html} />
    </div>
  </div>
</section>
