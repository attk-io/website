---
import { renderMarkdown } from '../lib/markdown';

type Props = {
  content: string;
};

const { content } = Astro.props;

const html = renderMarkdown(content, {
  h2: 'font-display text-[clamp(1.5rem,3vw,2rem)] font-medium text-sand-12 mb-8 pl-5 border-l-4 border-copper-9 leading-tight',
  p: 'text-sand-11 mb-5 last:mb-0',
  a: 'text-copper-9 underline underline-offset-[3px] decoration-1 decoration-copper-9/40 hover:decoration-copper-9',
});
---

<section class="px-6 py-[clamp(3.5rem,8vh,6rem)]">
  <div class="mx-auto max-w-[36rem]" set:html={html} />
</section>
