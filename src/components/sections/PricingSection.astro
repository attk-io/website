---
import { marked } from 'marked';

type Props = {
  content: string;
};

const { content } = Astro.props;
const html = await marked(content);
---

<section class="py-16 px-6">
  <div
    class:list={[
      'max-w-3xl mx-auto',
      '[&>h2]:font-serif [&>h2]:text-3xl [&>h2]:font-bold [&>h2]:mb-10',
      '[&>h3]:font-serif [&>h3]:text-xl [&>h3]:font-bold [&>h3]:mb-2 [&>h3]:mt-10 [&>h3:first-of-type]:mt-0',
      '[&>p]:text-muted [&>p]:leading-relaxed [&>p]:mb-4 [&>p:last-child]:mb-0',
      '[&>ul]:text-muted [&>ul]:leading-relaxed [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-4',
    ]}
    set:html={html}
  />
</section>
