const sunSwatches: Swatch[] = [
  { step: 1, oklch: 'oklch(0.995 0.007 92)' },
  { step: 2, oklch: 'oklch(0.983 0.020 92)' },
  { step: 3, oklch: 'oklch(0.962 0.038 92)' },
  { step: 4, oklch: 'oklch(0.938 0.062 92)' },
  { step: 5, oklch: 'oklch(0.908 0.088 92)' },
  { step: 6, oklch: 'oklch(0.875 0.108 92)' },
  { step: 7, oklch: 'oklch(0.832 0.128 92)' },
  { step: 8, oklch: 'oklch(0.782 0.148 92)' },
  { step: 9, oklch: 'oklch(0.870 0.175 92)' },
  { step: 10, oklch: 'oklch(0.832 0.170 92)' },
  { step: 11, oklch: 'oklch(0.442 0.108 78)' },
  { step: 12, oklch: 'oklch(0.268 0.068 68)' },
