  { step: 2, oklch: 'oklch(0.980 0.013 200)' },
  { step: 3, oklch: 'oklch(0.958 0.024 200)' },
  { step: 4, oklch: 'oklch(0.932 0.038 200)' },
  { step: 5, oklch: 'oklch(0.902 0.050 200)' },
  { step: 6, oklch: 'oklch(0.860 0.062 200)' },
  { step: 7, oklch: 'oklch(0.808 0.078 200)' },
  { step: 8, oklch: 'oklch(0.728 0.095 200)' },
  { step: 9, oklch: 'oklch(0.462 0.115 200)' },
  { step: 10, oklch: 'oklch(0.425 0.108 200)' },
  { step: 11, oklch: 'oklch(0.432 0.092 200)' },
  { step: 12, oklch: 'oklch(0.238 0.058 200)' },
