  { step: 9, oklch: 'oklch(0.305 0.102 252)' },
  { step: 10, oklch: 'oklch(0.268 0.095 252)' },
  { step: 11, oklch: 'oklch(0.355 0.098 252)' },
  { step: 12, oklch: 'oklch(0.188 0.062 252)' },
