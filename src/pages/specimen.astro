---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

type Hue = 'sand' | 'ink' | 'sun' | 'teal' | 'ocean' | 'plum';

type Swatch = {
  step: number;
  oklch: string;
};

// Parse OKLCH values from global.css so the specimen always documents the
// live token values. Regex matches `--color-{hue}-{step}: oklch(...);`.
const cssPath = path.resolve('src/styles/global.css');
const cssSource = fs.readFileSync(cssPath, 'utf8');
const tokenPattern =
  /--color-(sand|ink|sun|teal|ocean|plum)-(\d+):\s*(oklch\([^)]+\))/g;

const swatchesByHue: Record<Hue, Swatch[]> = {
  sand: [],
  ink: [],
  sun: [],
  teal: [],
  ocean: [],
  plum: [],
};

for (const match of cssSource.matchAll(tokenPattern)) {
  const [, hue, step, oklch] = match;
  swatchesByHue[hue as Hue].push({ step: Number(step), oklch });
}

for (const hue of Object.keys(swatchesByHue) as Hue[]) {
  swatchesByHue[hue].sort((a, b) => a.step - b.step);
}

const scales: {
  name: Hue;
  label: string;
  description: string;
  swatches: Swatch[];
}[] = [
  {
    name: 'sand',
    label: 'Sand',
    description: 'Cool neutral ramp — tinted toward ink for cohesion',
    swatches: swatchesByHue.sand,
  },
  {
    name: 'ink',
    label: 'Ink',
    description: 'Dark fountain-pen blue-violet — deep, literary',
    swatches: swatchesByHue.ink,
  },
  {
    name: 'sun',
    label: 'Sun',
    description: 'Sunshine yellow — bright, warm, joyful',
    swatches: swatchesByHue.sun,
  },
  {
    name: 'teal',
    label: 'Teal',
    description: 'Petrol peacock — cool, modern, restrained',
    swatches: swatchesByHue.teal,
  },
  {
    name: 'ocean',
    label: 'Ocean',
    description: 'Electric cyan-blue — the alive thread',
    swatches: swatchesByHue.ocean,
  },
  {
    name: 'plum',
    label: 'Plum',
    description: 'Deep aubergine — commercial signature',
    swatches: swatchesByHue.plum,
  },
];
