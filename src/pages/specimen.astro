<script>
  const toHex = (channel: number) =>
    Math.round(channel).toString(16).padStart(2, '0');

  // Round-trip the color through a canvas so the browser converts any
  // valid CSS color (oklch, rgb, hex, named) to an 8-bit sRGB pixel.
  const canvas = document.createElement('canvas');
  canvas.width = 1;
  canvas.height = 1;
  const ctx = canvas.getContext('2d');

  const toHexColor = (color: string): string | null => {
    if (!ctx) return null;
    ctx.clearRect(0, 0, 1, 1);
    ctx.fillStyle = '#000';
    ctx.fillStyle = color;
    ctx.fillRect(0, 0, 1, 1);
    const [r, g, b] = ctx.getImageData(0, 0, 1, 1).data;
    return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
  };

  const swatches =
    document.querySelectorAll<HTMLButtonElement>('[data-swatch]');

  for (const swatch of swatches) {
    swatch.addEventListener('click', async () => {
      const computed = getComputedStyle(swatch).backgroundColor;
      const hex = toHexColor(computed);
      if (!hex) return;
      try {
        await navigator.clipboard.writeText(hex);
      } catch {
        return;
      }
      const feedback = swatch.querySelector<HTMLElement>(
        '[data-swatch-feedback]'
      );
      if (!feedback) return;
      feedback.style.opacity = '1';
      window.setTimeout(() => {
        feedback.style.opacity = '0';
      }, 900);
    });
  }
</script>
