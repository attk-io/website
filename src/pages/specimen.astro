const oceanSwatches: Swatch[] = [
  { step: 1, oklch: 'oklch(0.992 0.005 218)' },
  { step: 2, oklch: 'oklch(0.980 0.014 218)' },
  { step: 3, oklch: 'oklch(0.955 0.028 218)' },
  { step: 4, oklch: 'oklch(0.928 0.044 218)' },
  { step: 5, oklch: 'oklch(0.895 0.062 218)' },
  { step: 6, oklch: 'oklch(0.852 0.082 218)' },
  { step: 7, oklch: 'oklch(0.795 0.105 218)' },
  { step: 8, oklch: 'oklch(0.715 0.135 218)' },
  { step: 9, oklch: 'oklch(0.522 0.168 218)' },
  { step: 10, oklch: 'oklch(0.475 0.158 218)' },
