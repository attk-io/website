  { step: 1, oklch: 'oklch(0.992 0.005 340)' },
  { step: 2, oklch: 'oklch(0.979 0.012 340)' },
  { step: 3, oklch: 'oklch(0.958 0.022 340)' },
  { step: 4, oklch: 'oklch(0.932 0.034 340)' },
