---
import BaseLayout from '../layouts/BaseLayout.astro';
import CopyVariantSection from '../components/CopyVariantSection.astro';
import V1 from '../components/copy-variants/v1.astro';
import V2 from '../components/copy-variants/v2.astro';
import V3 from '../components/copy-variants/v3.astro';
import V4 from '../components/copy-variants/v4.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="ATTK Software">
  <div class="font-sans text-primary bg-page">
    <CopyVariantSection>
      <V1 slot="v1" />
      <V2 slot="v2" />
      <V3 slot="v3" />
      <V4 slot="v4" />
    </CopyVariantSection>
    <Footer />
  </div>
</BaseLayout>
