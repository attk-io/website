---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Attack Software">
  <section>
    <header>
      <h1 class="brand-title"><span>Attack</span> Software</h1>
      <p class="brand-tagline">
        Custom cloud software and automation consulting
      </p>
    </header>

    <main>
      <p>
        Attack Software provides consulting and contracting services to
        ambitious startups and estabilished businesses. We specialize in
        project management and team development are dedicated to ensuring that
        the solutions we provide are practical and sustainable.
      </p>
    </main>

    <address>
      <h1 class="contact-name">Christian Naths</h1>
      <p class="contact-title">Principal Consultant</p>

      <a class="contact-link" href="mailto:christiannaths@gmail.com">
        christiannaths@gmail.com
      </a>
    </address>
    <footer>
      &copy;2025 Attk Software Inc.

      <a href="/terms-of-service/">Terms of Service</a>
      <a href="/privacy-policy/">Privacy Policy</a>
    </footer>
  </section>
</BaseLayout>

<style>
  html {
    font-family: var(--font-sans);
    color: var(--color-primary);
    background-color: var(--color-surface);
  }

  body {
    font-size: 100%;
    line-height: 1.7;
  }

  section {
    background-color: var(--color-surface);
    position: relative;
    z-index: 0;
    padding: 1.5rem 2rem;
  }

  header,
  main,
  address,
  footer {
    margin: 4.5rem 0;
  }

  footer {
    margin-bottom: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-separator);
    display: grid;
    gap: 0.25rem;
    font-size: small;
  }

  footer a {
    color: var(--color-primary);
    font-size: small;
    font-style: italic;
    font-weight: 400;
    background-color: transparent;
    text-decoration: underline;
  }

  footer a::before {
    background-color: transparent;
  }

  h1 {
    font-family: var(--font-serif);
    line-height: 1.2;
    font-size: 2.25rem;
  }

  .brand-title span {
    position: relative;
  }

  .brand-title span::before {
    content: '';
    background-color: var(--color-accent);
    position: absolute;
    height: 0.4375rem;
    width: 200%;
    z-index: -1;
    transform: translate(-48%, 0.5666667em);
  }

  .brand-tagline {
    font-size: 1.5em;
  }

  a {
    color: inherit;
    font-weight: bold;
    text-decoration: none;
    position: relative;
  }

  a::before {
    content: '';
    background-color: var(--color-accent);
    position: absolute;
    height: 0.4375rem;
    width: 120%;
    z-index: -1;
    transform: translate(-10%, 0.5666667em);
  }

  address {
    font-style: normal;
  }

  address > * {
    font-size: 1rem;
    margin: 0;
  }

  .contact-name {
    font-size: 1.25rem;
    margin: 0;
  }

  .contact-title {
    font-size: 0.9em;
    margin: 0;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  @media (min-width: 36rem) {
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background-color: var(--color-page);
    }

    section {
      margin: 2rem;
      max-width: 48rem;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      padding: 2rem;
    }
  }
</style>
