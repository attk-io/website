---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderSection from '../components/HeaderSection.astro';
import HeroSection from '../components/HeroSection.astro';
import WhoThisIsForSection from '../components/WhoThisIsForSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import AboutSection from '../components/AboutSection.astro';
import PricingSection from '../components/PricingSection.astro';
import FAQSection from '../components/FAQSection.astro';
import FinalCTASection from '../components/FinalCTASection.astro';
import Footer from '../components/Footer.astro';

import heroContent from '../content/hero.md?raw';
import whoThisIsForContent from '../content/who-this-is-for.md?raw';
import howItWorksContent from '../content/how-it-works.md?raw';
import aboutContent from '../content/about.md?raw';
import pricingContent from '../content/pricing.md?raw';
import faqContent from '../content/faq.md?raw';
import finalCtaContent from '../content/final-cta.md?raw';
---

<BaseLayout title="ATTK Software">
  <HeaderSection />
  <main>
    <HeroSection content={heroContent} />
    <WhoThisIsForSection content={whoThisIsForContent} number="01" label="Who This Is For" />
    <HowItWorksSection content={howItWorksContent} number="02" label="How It Works" />
    <AboutSection content={aboutContent} number="03" label="About" />
    <PricingSection content={pricingContent} number="04" label="Pricing" />
    <FAQSection content={faqContent} number="05" label="FAQ" />
    <FinalCTASection content={finalCtaContent} />
  </main>
  <Footer />
</BaseLayout>
