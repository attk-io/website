---
import BaseLayout from '../layouts/BaseLayout.astro';
import CopyVariantSection from '../components/CopyVariantSection.astro';
import HeroV1 from '../components/copy-variants/Hero/v1.astro';
import HeroV2 from '../components/copy-variants/Hero/v2.astro';
import WhoThisIsFor from '../components/WhoThisIsFor.astro';
import FrameworkTimeline from '../components/FrameworkTimeline.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="ATTK Software">
  <div class="font-sans text-primary bg-page">
    <CopyVariantSection section="Hero">
      <HeroV1 slot="v1" />
      <HeroV2 slot="v2" />
    </CopyVariantSection>
    <WhoThisIsFor />
    <FrameworkTimeline />
    <About />
    <FAQ />
    <FinalCTA />
    <Footer />
  </div>
</BaseLayout>
