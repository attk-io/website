---
// Font pairing demo — compare typography options for Quiet Authority variant
import VariantLayout from '../../layouts/VariantLayout.astro';
import { marked } from 'marked';

const heroMarkdown = `# I build software for founders who need to get it right

### A decade of experience shipping products that last. One person who takes full ownership of the technical side — so you can focus on building the business.

[Let's talk](#)`;

const heroHtml = await marked(heroMarkdown);

const pairings = [
  {
    label: 'Fraunces + DM Sans (current)',
    heading: "'Fraunces', serif",
    body: "'DM Sans', sans-serif",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap',
  },
  {
    label: 'EB Garamond + DM Mono',
    heading: "'EB Garamond', serif",
    body: "'DM Mono', monospace",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap',
  },
  {
    label: 'Prata + Karla',
    heading: "'Prata', serif",
    body: "'Karla', sans-serif",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=Prata&family=Karla:ital,wght@0,200..800;1,200..800&display=swap',
  },
  {
    label: 'Hanken Grotesk + Inter',
    heading: "'Hanken Grotesk', sans-serif",
    body: "'Inter', sans-serif",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap',
  },
  {
    label: 'Quicksand + Roboto Slab',
    heading: "'Quicksand', sans-serif",
    body: "'Roboto Slab', serif",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=Quicksand:wght@300..700&family=Roboto+Slab:wght@100..900&display=swap',
  },
  {
    label: 'Fraunces + Open Sans',
    heading: "'Fraunces', serif",
    body: "'Open Sans', sans-serif",
    googleUrl:
      'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap',
  },
];
---

<VariantLayout title="Font Pairing Demo — Quiet Authority" variant="quiet-authority">
  <main>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {pairings.map((p) => <link href={p.googleUrl} rel="stylesheet" />)}

    <div class="demo-header">
      <h1>Font Pairing Comparison</h1>
      <p>Quiet Authority variant — scroll to compare pairings</p>
    </div>

    {
      pairings.map((p, i) => (
        <section
          class="hero-demo"
          style={`--heading-font: ${p.heading}; --body-font: ${p.body};`}
        >
          <div class="pairing-label">
            <span class="pairing-number">{String(i + 1).padStart(2, '0')}</span>
            <span class="pairing-name">{p.label}</span>
          </div>
          <div class="hero-inner" set:html={heroHtml} />
        </section>
      ))
    }
  </main>
</VariantLayout>

<style>
  main {
    background: #faf7f2;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .demo-header {
    padding: 3rem 1.5rem 2rem;
    text-align: center;
    border-bottom: 1px solid #c9bfb2;
  }

  .demo-header h1 {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #5a5148;
    margin: 0 0 0.5rem;
  }

  .demo-header p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: #8a7e72;
    margin: 0;
  }

  .hero-demo {
    padding: clamp(5rem, 14vh, 10rem) 1.5rem clamp(4rem, 12vh, 7rem);
    text-align: center;
    border-bottom: 2px solid #c9bfb2;
    position: relative;
  }

  .pairing-label {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .pairing-number {
    font-family: 'DM Mono', 'DM Sans', monospace;
    font-size: 0.75rem;
    color: #b84c2a;
    font-weight: 500;
  }

  .pairing-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: #5a5148;
    letter-spacing: 0.02em;
  }

  .hero-inner {
    max-width: 38rem;
    margin: 0 auto;
  }

  .hero-demo :global(h1) {
    font-family: var(--heading-font);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #2c2622;
    margin: 0 0 1.75rem;
  }

  .hero-demo :global(h3) {
    font-family: var(--body-font);
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    font-weight: 400;
    line-height: 1.65;
    color: #5a5148;
    margin: 0 auto 2.5rem;
    max-width: 30rem;
    letter-spacing: 0;
  }

  .hero-demo :global(p) {
    margin: 0;
  }

  .hero-demo :global(a) {
    display: inline-block;
    background: #b84c2a;
    color: #faf7f2;
    text-decoration: none;
    font-family: var(--body-font);
    font-size: 1.05rem;
    font-weight: 500;
    padding: 0.85rem 2.25rem;
    border-radius: 3px;
    transition: background 0.2s ease;
  }

  .hero-demo :global(a:hover) {
    background: #a34122;
  }
</style>
